@model int
@{ Layout = null; }
<form method="post" action="/Order/Finish/@Model">
    <div class="modal-header text-bg-success">
        <strong class="modal-title"><i class="bi bi-flag-fill me-1"></i>Hoàn tất đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-secondary d-flex align-items-center mb-0">
            <i class="bi bi-flag-fill me-2 fs-4"></i>
            <span>Xác nhận đơn hàng đã được giao thành công?</span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-success"><i class="bi bi-check2 me-1"></i>Hoàn tất</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
