@model int
@{ Layout = null; }
<form method="post" action="/Order/Cancel/@Model">
    <div class="modal-header text-bg-warning">
        <strong class="modal-title"><i class="bi bi-slash-circle me-1"></i>Hủy đơn hàng</strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="alert alert-secondary d-flex align-items-center mb-0">
            <i class="bi bi-slash-circle me-2 fs-4"></i>
            <span>Bạn có chắc muốn hủy đơn hàng này?</span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-check2 me-1"></i>Xác nhận hủy</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>
