@model List<SV22T1020469.Models.Sales.OrderDetailViewInfo>
@{ Layout = null; decimal sum = 0; int stt = 0; }

<div class="card card-outline card-success">
    <div class="card-header d-flex justify-content-between align-items-center py-2">
        <h6 class="mb-0"><i class="bi bi-cart me-1"></i>Mặt hàng đã chọn</h6>
        @if (Model.Any())
        {
            <a class="btn btn-sm btn-outline-danger open-modal" href="/Order/ClearCartConfirm">
                <i class="bi bi-trash"></i> Xóa giỏ
            </a>
        }
    </div>
    @if (!Model.Any())
    {
        <div class="card-body text-muted text-center py-4">
            <i class="bi bi-cart-x fs-2"></i><br/>Chưa có mặt hàng nào
        </div>
    }
    else
    {
        <div class="card-body p-0 table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead class="table-success">
                    <tr>
                        <th class="text-center" style="width:35px">#</th>
                        <th>Tên hàng</th>
                        <th class="text-center" style="width:60px">ĐVT</th>
                        <th class="text-center" style="width:60px">SL</th>
                        <th class="text-end" style="width:110px">Giá (đ)</th>
                        <th class="text-end" style="width:120px">T.Tiền (đ)</th>
                        <th style="width:70px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        sum += item.TotalPrice;
                        <tr>
                            <td class="text-center">@(++stt)</td>
                            <td class="small">@item.ProductName</td>
                            <td class="text-center small">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end small">@item.SalePrice.ToString("N0")</td>
                            <td class="text-end small fw-bold">@item.TotalPrice.ToString("N0")</td>
                            <td class="text-center text-nowrap">
                                <a class="btn btn-xs btn-primary open-modal p-1"
                                   href="/Order/EditCartItem?productId=@item.ProductID" title="Sửa">
                                    <i class="bi bi-pencil-fill" style="font-size:.7rem"></i>
                                </a>
                                <a class="btn btn-xs btn-danger open-modal p-1"
                                   href="/Order/DeleteCartItem?productId=@item.ProductID" title="Xóa">
                                    <i class="bi bi-dash-lg" style="font-size:.7rem"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-success">
                    <tr>
                        <th colspan="5" class="text-end">Tổng cộng:</th>
                        <th class="text-end text-danger">@sum.ToString("N0")</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
