@model SV22T1020469.Models.Catalog.ProductSearchInput
@using SV22T1020605.Admin
@{
    ViewBag.Title = "Lập đơn hàng mới";
}

<div class="row">
    <!-- CỘT TRÁI: Tìm sản phẩm -->
    <div class="col-4">
        <div class="card card-outline card-primary" style="min-height:500px">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-search me-1"></i>Chọn mặt hàng cần bán</h6>
            </div>
            <div class="card-body pb-1">
                <form id="formSearch" method="get" action="/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event,this,1)">
                    <input type="hidden" asp-for="PageSize" />
                    <div class="input-group">
                        <input class="form-control" asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng..." autofocus />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
            <div id="searchResult" class="p-2 overflow-auto" style="max-height:520px"></div>
        </div>
    </div>

    <!-- CỘT PHẢI: Giỏ hàng + Thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div id="cart" class="mb-3"></div>

        <!-- Form lập đơn -->
        <div class="card card-outline card-info">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-person me-1"></i>Thông tin khách hàng &amp; giao hàng</h6>
            </div>
            <div class="card-body">
                <form onsubmit="createOrder(event,this)">

                    <!-- Tìm khách hàng -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Khách hàng <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <div class="input-group">
                                <input type="text" id="customerSearch" class="form-control"
                                       placeholder="Nhập tên để tìm khách hàng..." autocomplete="off" />
                                <button type="button" class="btn btn-outline-secondary"
                                        onclick="searchCustomers()">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <select id="customerSelect" class="form-select mt-1"
                                    size="4" style="display:none">
                            </select>
                            <input type="hidden" id="customerIDHidden" name="customerID" value="0" />
                            <div id="customerInfo" class="mt-1 small text-success"></div>
                            <span id="customerValidationMessage" class="text-danger small d-block mt-1"></span>
                            <div id="orderCreateMessage" class="mt-2"></div>
                        </div>
                    </div>

                    <!-- Tỉnh/Thành -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Tỉnh/Thành <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <select class="form-select" name="deliveryProvince" id="deliveryProvince">
                                <option value="">-- Chọn tỉnh/thành --</option>
                                @foreach (var p in await SelectListHelper.Provinces())
                                {
                                    if (p.Value != "")
                                    {
                                        <option value="@p.Value">@p.Text</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Địa chỉ -->
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-semibold">
                            Địa chỉ <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <textarea class="form-control" name="deliveryAddress" id="deliveryAddress"
                                      rows="2" placeholder="Số nhà, tên đường, phường/xã..."></textarea>
                        </div>
                    </div>

                    <div class="text-end">
                        <button class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle me-1"></i>Lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {
        paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        showCart();
    });

    // ── GIỎ HÀNG ──────────────────────────────────────────────────────────
    function showCart() {
        fetch("/Order/ShowCart")
            .then(r => r.text())
            .then(html => {
                document.getElementById("cart").innerHTML = html;
                attachOpenModal(document.getElementById("cart"));
            });
    }

    function addCartItem(event, form) {
        event.preventDefault();
        fetch("/Order/AddToCart", { method: "POST", body: new FormData(form) })
            .then(r => r.json())
            .then(result => {
                if (result.code == 0) alert(result.message);
                else showCart();
            });
    }

    function deleteCartItem(productID) {
        const fd = new FormData();
        fd.append("productID", productID);
        fetch("/Order/DeleteCartItem", { method: "POST", body: fd })
            .then(() => showCart());
    }

    function clearCart() {
        fetch("/Order/ClearCart", { method: "POST" }).then(() => showCart());
    }

    function updateCartItem(event, form) {
        event.preventDefault();
        fetch("/Order/UpdateCartItem", { method: "POST", body: new FormData(form) })
            .then(r => r.json())
            .then(result => {
                if (result.code == 0) { alert(result.message); return; }
                const m = bootstrap.Modal.getInstance(document.getElementById("dialogModal"));
                if (m) m.hide();
                showCart();
            });
    }

    // ── TÌM KHÁCH HÀNG ────────────────────────────────────────────────────
    let customerList = [];

    function searchCustomers() {
        const q = document.getElementById("customerSearch").value;
        fetch("/Order/GetCustomers?searchValue=" + encodeURIComponent(q))
            .then(r => r.json())
            .then(data => {
                customerList = data;
                const sel = document.getElementById("customerSelect");
                sel.innerHTML = "";

                if (!data.length) {
                    sel.innerHTML = "<option disabled>Không tìm thấy khách hàng nào</option>";
                    sel.style.display = "block";
                    return;
                }

                data.forEach(c => {
                    const opt = document.createElement("option");
                    opt.value = c.id;
                    opt.text  = c.name + (c.phone ? " – " + c.phone : "");
                    sel.appendChild(opt);
                });
                sel.style.display = "block";
            });
    }

    document.getElementById("customerSelect").addEventListener("change", function () {
        const c = customerList.find(x => x.id == parseInt(this.value));
        if (!c) return;
        document.getElementById("customerIDHidden").value = c.id;
        document.getElementById("customerSearch").value   = c.name;
        document.getElementById("customerInfo").innerHTML =
            `✅ <strong>${c.name}</strong>${c.phone ? " | " + c.phone : ""}`;
        document.getElementById("customerSelect").style.display = "none";

        // Pre-fill địa chỉ
        if (c.address) document.getElementById("deliveryAddress").value = c.address;
        if (c.province) {
            const sel = document.getElementById("deliveryProvince");
            for (let opt of sel.options) {
                if (opt.value === c.province) { opt.selected = true; break; }
            }
        }
    });

    document.getElementById("customerSearch").addEventListener("keydown", function (e) {
        if (e.key === "Enter") { e.preventDefault(); searchCustomers(); }
    });

    // ── LẬP ĐƠN ───────────────────────────────────────────────────────────
    function createOrder(event, form) {
        event.preventDefault();
        const customerID = parseInt(document.getElementById("customerIDHidden").value);
        const customerValidationMessage = document.getElementById("customerValidationMessage");
        const orderCreateMessage = document.getElementById("orderCreateMessage");
        customerValidationMessage.textContent = "";
        orderCreateMessage.innerHTML = "";

        if (customerID <= 0) {
            customerValidationMessage.textContent = "Vui lòng tìm và chọn khách hàng!";
            return;
        }

        const fd = new FormData(form);
        fd.set("customerID", customerID);

        fetch("/Order/CreateOrder", { method: "POST", body: fd })
            .then(r => r.json())
            .then(result => {
                if (result.code == 0) {
                    orderCreateMessage.innerHTML =
                        `<div class="alert alert-danger py-2 mb-0">${result.message}</div>`;
                    return;
                }
                window.location.href = "/Order/Details/" + result.message;
            });
    }
</script>
}
