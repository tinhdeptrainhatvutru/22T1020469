@model SV22T1020469.Models.DashboardModel
@using System.Linq
@using System.Text.Json

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Doanh thu hôm nay</h6>
                        <h3 class="mb-0">@Model.TodayRevenue.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">@Model.TotalOrders</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@Model.TotalCustomers</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@Model.TotalProducts</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" height="150"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (Model.TopProducts.Any())
                    {
                        foreach (var product in Model.TopProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                @product.ProductName
                                <span class="badge bg-success">@product.SoldQuantity</span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">Chưa có dữ liệu bán hàng</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PendingOrders.Any())
                        {
                            foreach (var order in Model.PendingOrders)
                            {
                                <tr>
                                    <td>#DH@order.OrderID.ToString("D5")</td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.OrderTime.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@order.TotalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (order.Status == SV22T1020469.Models.Sales.OrderStatusEnum.New)
                                        {
                                            <span class="badge bg-danger">Đang chờ duyệt</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Chờ giao hàng</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-3">Không có đơn hàng nào cần xử lý</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart');

        const revenueData = @Html.Raw(JsonSerializer.Serialize(Model.RevenueByMonths));

        new Chart(ctx, {
            type: 'bar', // bar | line | pie | doughnut
            data: {
                labels: [
                    'Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6',
                    'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'
                ],
                datasets: [{
                    label: 'Doanh thu (VND)',
                    data: revenueData,
                    backgroundColor: 'rgba(13,110,253,0.7)',
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function (context) {
                                return Number(context.raw).toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}