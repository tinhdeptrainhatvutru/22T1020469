@model SV22T1020469.Models.Common.PagedResult<SV22T1020469.Models.Partner.Customer>
@{
    Layout = null;

    int totalPages = Model.PageCount;
    int currentPage = Model.Page;
    int windowSize = 2; // 2 trang mỗi bên => tối đa 5 trang quanh current

    int startPage = Math.Max(1, currentPage - windowSize);
    int endPage = Math.Min(totalPages, currentPage + windowSize);

    if (endPage - startPage + 1 < 5)
    {
        int missing = 5 - (endPage - startPage + 1);
        if (startPage > 1) startPage = Math.Max(1, startPage - missing);
        else if (endPage < totalPages) endPage = Math.Min(totalPages, endPage + missing);
    }
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> khách hàng
</div>

<div class="card">
    <div class="card-body p-1 table-responsive">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Tên khách hàng</th>
                    <th>Tên giao dịch</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th>Tỉnh / Thành</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="width:130px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems != null && Model.DataItems.Count > 0)
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.CustomerName</td>
                            <td>@item.ContactName</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td>@item.Province</td>
                            <td class="text-center">
                                @if (item.IsLocked == true)
                                {
                                    <span class="badge bg-danger">Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="~/Customer/ChangePassword/@item.CustomerID" class="btn btn-sm btn-warning">
                                    <i class="bi bi-key"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted">Không tìm thấy dữ liệu!</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    @if (currentPage == 1)
                    {
                        <span class="page-link" aria-hidden="true">&laquo;&laquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), 1)"
                           aria-label="Trang đầu">&laquo;&laquo;</a>
                    }
                </li>

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    @if (currentPage == 1)
                    {
                        <span class="page-link" aria-hidden="true">&laquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @(currentPage - 1))"
                           aria-label="Trang trước">&laquo;</a>
                    }
                </li>

                @for (int p = startPage; p <= endPage; p++)
                {
                    if (p == 1 || p == totalPages) { continue; }

                    if (p == currentPage)
                    {
                        <li class="page-item active"><span class="page-link">@p</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">@p</a>
                        </li>
                    }
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    @if (currentPage == totalPages)
                    {
                        <span class="page-link" aria-hidden="true">&raquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @(currentPage + 1))"
                           aria-label="Trang tiếp">&raquo;</a>
                    }
                </li>

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    @if (currentPage == totalPages)
                    {
                        <span class="page-link" aria-hidden="true">&raquo;&raquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @totalPages)"
                           aria-label="Trang cuối">&raquo;&raquo;</a>
                    }
                </li>

            </ul>
        </div>
    }
</div>