@model SV22T1020469.Models.Partner.Supplier
@{
    ViewBag.Title = "Xóa nhà cung cấp";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i> Xác nhận xóa
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa nhà cung cấp
                </h5>
            </div>
            <div class="card-body">
                <form id="formDelete" action="~/Supplier/Delete/@Model.SupplierID" method="post">
                    <input type="hidden" name="SupplierID" value="@Model.SupplierID" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2 fs-4"></i>
                        <div>
                            Bạn có chắc chắn muốn xóa nhà cung cấp <strong>@Model.SupplierName</strong> không?<br />
                            <small class="text-muted">Hành động này không thể hoàn tác.</small>
                        </div>
                    </div>

                    <dl class="row mb-0 mt-4">
                        <dt class="col-sm-3">Tên nhà cung cấp</dt>
                        <dd class="col-sm-9 fw-bold">@Model.SupplierName</dd>

                        <dt class="col-sm-3">Tên giao dịch</dt>
                        <dd class="col-sm-9">@Model.ContactName</dd>

                        <dt class="col-sm-3">Điện thoại</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>

                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Địa chỉ</dt>
                        <dd class="col-sm-9">@Model.Address, @Model.Province</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>