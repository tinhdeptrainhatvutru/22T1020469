@model SV22T1020469.Models.Partner.Shipper

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save me-1"></i> Lưu dữ liệu
    </button>
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i> Thông tin người giao hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Shipper/Save" method="post">
                    <input type="hidden" name="ShipperID" value="@Model.ShipperID" />
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                    <div class="mb-3">
                        <label class="form-label">Tên người giao hàng <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="ShipperName" value="@Model.ShipperName" autofocus />
                        @Html.ValidationMessage("ShipperName", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Điện thoại <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="Phone" value="@Model.Phone" />
                        @Html.ValidationMessage("Phone", new { @class = "text-danger" })
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>