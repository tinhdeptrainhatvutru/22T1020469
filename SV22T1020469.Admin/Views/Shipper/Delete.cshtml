@model SV22T1020469.Models.Partner.Shipper
@{
    ViewBag.Title = "Xóa người giao hàng";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i> Xác nhận xóa
    </button>
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="card-title mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i> Xác nhận xóa người giao hàng
                </h5>
            </div>
            <div class="card-body">
                <form id="formDelete" action="~/Shipper/Delete/@Model.ShipperID" method="post">
                    <input type="hidden" name="ShipperID" value="@Model.ShipperID" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-2 fs-4"></i>
                        <div>
                            Bạn có chắc chắn muốn xóa người giao hàng <strong>@Model.ShipperName</strong> không?<br />
                            <small class="text-muted">Hành động này không thể hoàn tác.</small>
                        </div>
                    </div>

                    <dl class="row mb-0 mt-4">
                        <dt class="col-sm-3">Tên người giao hàng</dt>
                        <dd class="col-sm-9 fw-bold">@Model.ShipperName</dd>

                        <dt class="col-sm-3">Điện thoại</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>