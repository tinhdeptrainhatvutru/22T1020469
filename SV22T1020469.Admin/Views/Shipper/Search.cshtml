@model SV22T1020469.Models.Common.PagedResult<SV22T1020469.Models.Partner.Shipper>
@{
    Layout = null;
    int maxPagesToShow = 5;
    int startPage = Math.Max(1, Model.Page - maxPagesToShow / 2);
    int endPage = Math.Min(Model.PageCount, startPage + maxPagesToShow - 1);
    if (endPage - startPage + 1 < maxPagesToShow)
    {
        startPage = Math.Max(1, endPage - maxPagesToShow + 1);
    }
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> người giao hàng
</div>

<div class="card">
    <div class="card-body p-1 table-responsive">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Tên người giao hàng</th>
                    <th>Điện thoại</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Count > 0)
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>@item.ShipperName</td>
                            <td>@item.Phone</td>
                            <td class="text-center text-nowrap">
                                <a href="~/Shipper/Edit/@item.ShipperID" class="btn btn-sm btn-info" title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a href="~/Shipper/Delete/@item.ShipperID" class="btn btn-sm btn-danger" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted">Không tìm thấy dữ liệu!</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">&laquo;</a>
                </li>
                @for (int p = startPage; p <= endPage; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">@p</a>
                    </li>
                }
                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">&raquo;</a>
                </li>
            </ul>
        </div>
    }
</div>