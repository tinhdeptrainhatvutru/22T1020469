@model SV22T1020469.Models.Common.PagedResult<SV22T1020469.Models.HR.Employee>
@{
    Layout = null;

    int totalPages = Model.PageCount;
    int currentPage = Model.Page;
    int windowSize = 2; // 2 trang mỗi bên => tối đa 5 trang quanh current

    int startPage = Math.Max(1, currentPage - windowSize);
    int endPage = Math.Min(totalPages, currentPage + windowSize);

    if (endPage - startPage + 1 < 5)
    {
        int missing = 5 - (endPage - startPage + 1);
        if (startPage > 1) startPage = Math.Max(1, startPage - missing);
        else if (endPage < totalPages) endPage = Math.Min(totalPages, endPage + missing);
    }
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1 table-responsive">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th style="width: 80px;">Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th style="width:120px;">Trạng thái</th>
                    <th style="width:150px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Count > 0)
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="@((string.IsNullOrEmpty(item.Photo))
                                            ? "/images/employees/nophoto.png"
                                            : (item.Photo == "nophoto.svg"
                                                ? "/images/nophoto.svg"
                                                : "/images/employees/" + item.Photo))"
                                     onerror="this.src='/images/nophoto.svg'"
                                     alt="Avatar" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;" />
                            </td>
                            <td class="fw-bold">@item.FullName</td>
                            <td class="text-center">@(item.BirthDate?.ToString("dd/MM/yyyy"))</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td class="text-center">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-info" title="Sửa"><i class="bi bi-pencil-square"></i></a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa"><i class="bi bi-trash"></i></a>
                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning" title="Đổi mật khẩu"><i class="bi bi-key"></i></a>
                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-secondary" title="Phân quyền"><i class="bi bi-shield-lock"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted">Không tìm thấy dữ liệu!</td></tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    @if (currentPage == 1)
                    {
                        <span class="page-link" aria-hidden="true">&laquo;&laquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), 1)"
                           aria-label="Trang đầu">&laquo;&laquo;</a>
                    }
                </li>

                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    @if (currentPage == 1)
                    {
                        <span class="page-link" aria-hidden="true">&laquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @(currentPage - 1))"
                           aria-label="Trang trước">&laquo;</a>
                    }
                </li>

                @for (int p = startPage; p <= endPage; p++)
                {
                    if (p == 1 || p == totalPages) { continue; }

                    if (p == currentPage)
                    {
                        <li class="page-item active"><span class="page-link">@p</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="paginationSearch(event, document.getElementById('formSearch'), @p)">@p</a>
                        </li>
                    }
                }

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    @if (currentPage == totalPages)
                    {
                        <span class="page-link" aria-hidden="true">&raquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @(currentPage + 1))"
                           aria-label="Trang tiếp">&raquo;</a>
                    }
                </li>

                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    @if (currentPage == totalPages)
                    {
                        <span class="page-link" aria-hidden="true">&raquo;&raquo;</span>
                    }
                    else
                    {
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @totalPages)"
                           aria-label="Trang cuối">&raquo;&raquo;</a>
                    }
                </li>
            </ul>
        </div>
    }
</div>