@model SV22T1020469.Models.HR.Employee
@{
    ViewBag.Title = "Mật khẩu nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-warning">
        <i class="bi bi-key me-1"></i> Lưu mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" action="~/Employee/ChangePassword" method="post">
                    <input type="hidden" name="id" value="@Model.EmployeeID" />
                    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2"><i class="bi bi-person me-1"></i> Thông tin nhân viên</legend>
                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9 fw-bold">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2"><i class="bi bi-key me-1"></i> Thông tin mật khẩu</legend>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="newPassword" class="form-control" />
                            @Html.ValidationMessage("newPassword", new { @class = "text-danger" })
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" name="confirmPassword" class="form-control" />
                            @Html.ValidationMessage("confirmPassword", new { @class = "text-danger" })
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>