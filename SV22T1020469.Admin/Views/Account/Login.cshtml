@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Đăng nhập") – Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-light">
    <main class="container py-5" style="min-height: 100vh;">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card shadow border-0">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="bi bi-shield-lock text-primary" style="font-size:3rem"></i>
                            <h4 class="fw-bold mt-2 mb-1">Đăng nhập Admin</h4>
                            <p class="text-muted small mb-0">Quản trị hệ thống HTB Shop</p>
                        </div>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success py-2 small shadow-sm">
                                <i class="bi bi-check-circle-fill me-1"></i>@TempData["SuccessMessage"]
                            </div>
                        }

                        <form method="post" asp-controller="Account" asp-action="Login" novalidate>
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="All" class="alert alert-danger py-2 small"
                                 style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    <input type="email" name="UserName" class="form-control"
                                           value="@ViewBag.Username" placeholder="example@email.com"
                                           autocomplete="email" required autofocus />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Mật khẩu <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                    <input type="password" name="Password" id="pwdInput" class="form-control"
                                           placeholder="Nhập mật khẩu" autocomplete="current-password" required />
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePwd('pwdInput', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-lg fw-bold">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                                </button>
                            </div>

                            <div class="text-center mb-2">
                                <a asp-controller="Account" asp-action="ForgotPassword" class="small">Quên mật khẩu?</a>
                            </div>

                            <div class="text-center">
                                <span class="text-muted small">Chưa có tài khoản?</span>
                                <a asp-controller="Account" asp-action="Register" class="fw-semibold ms-1">Đăng ký</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePwd(inputId, btn) {
            const inp = document.getElementById(inputId);
            const icon = btn.querySelector('i');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                inp.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
</body>

</html>
