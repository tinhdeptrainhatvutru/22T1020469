@model SV22T1020469.Models.Catalog.Product
@{
    Layout = null;
    var photos = ViewBag.Photos as List<SV22T1020469.Models.Catalog.ProductPhoto>;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 id="photos" class="mb-0"><i class="bi bi-images me-2"></i> Thư viện ảnh</h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Photo/@Model.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i> Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1 table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px" class="text-center">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px" class="text-center">Hiển thị</th>
                            <th style="width:100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (photos != null && photos.Count > 0)
                        {
                            foreach (var item in photos)
                            {
                                <tr>
                                    <td class="text-center align-middle">
                                        <img src="@(string.IsNullOrEmpty(item.Photo)
                                                    ? "/images/nophoto.svg"
                                                    : (item.Photo.StartsWith("nophoto.", StringComparison.OrdinalIgnoreCase)
                                                        ? $"/images/{item.Photo}"
                                                        : (item.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase)
                                                            ? $"/images/{item.Photo}"
                                                            : $"/images/products/{item.Photo}")))"
                                             onerror="this.src='/images/nophoto.svg'"
                                             class="img-thumbnail" style="max-height:80px;object-fit:cover;" />
                                    </td>
                                    <td class="align-middle">@item.Description</td>
                                    <td class="text-center align-middle">@item.DisplayOrder</td>
                                    <td class="text-center align-middle">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center align-middle text-nowrap">
                                        <a class="btn btn-sm btn-outline-primary" href="~/Product/Photo/@Model.ProductID?method=edit&photoId=@item.PhotoID"><i class="bi bi-pencil"></i></a>
                                        <a class="btn btn-sm btn-outline-danger" href="~/Product/Photo/@Model.ProductID?method=delete&photoId=@item.PhotoID"><i class="bi bi-trash"></i></a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted">Chưa có ảnh nào được thêm</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>