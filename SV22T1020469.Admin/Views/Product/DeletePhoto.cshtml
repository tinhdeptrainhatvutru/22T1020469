@model SV22T1020469.Models.Catalog.ProductPhoto
@{
    ViewBag.Title = "Xóa ảnh mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger">
        <i class="bi bi-trash"></i> Xác nhận xóa
    </button>
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="mb-0 text-danger"><i class="bi bi-exclamation-triangle me-2"></i> Bạn có chắc chắn muốn xóa ảnh này?</h5>
    </div>
    <div class="card-body text-center">
        <form id="formDelete" action="~/Product/DeletePhoto" method="post">
            <input type="hidden" name="photoId" value="@Model.PhotoID" />
            <input type="hidden" name="productId" value="@Model.ProductID" />

            <img src="@(string.IsNullOrEmpty(Model.Photo)
                        ? "/images/nophoto.svg"
                        : (Model.Photo.StartsWith("nophoto.", StringComparison.OrdinalIgnoreCase)
                            ? $"/images/{Model.Photo}"
                            : (Model.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase)
                                ? $"/images/{Model.Photo}"
                                : $"/images/products/{Model.Photo}")))"
                 onerror="this.src='/images/nophoto.svg'"
                 class="img-thumbnail mb-3" style="max-height: 250px;object-fit:cover" />

            <p class="fs-5">Mô tả: <strong>@Model.Description</strong></p>
        </form>
    </div>
</div>