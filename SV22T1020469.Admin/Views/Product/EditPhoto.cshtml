@model SV22T1020469.Models.Catalog.ProductPhoto
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu ảnh
    </button>
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-image me-2"></i> Thông tin ảnh mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Upload Ảnh mới</label>
                        <div class="col-sm-9">
                            <input type="file" name="uploadPhoto" class="form-control" accept="image/*" />
                            @Html.ValidationMessage("Photo", new { @class = "text-danger" })
                            <div class="mt-3">
                                <img src="@(string.IsNullOrEmpty(Model.Photo)
                                            ? "/images/nophoto.svg"
                                            : (Model.Photo.StartsWith("nophoto.", StringComparison.OrdinalIgnoreCase)
                                                ? $"/images/{Model.Photo}"
                                                : (Model.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase)
                                                    ? $"/images/{Model.Photo}"
                                                    : $"/images/products/{Model.Photo}")))"
                                     onerror="this.src='/images/nophoto.svg'"
                                     class="img-thumbnail" style="max-height: 200px; object-fit:cover;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả ảnh</label>
                        <div class="col-sm-9">
                            <input type="text" name="Description" value="@Model.Description" class="form-control" placeholder="Nhập mô tả (VD: Ảnh mặt trước...)" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" name="DisplayOrder" value="@Model.DisplayOrder" class="form-control" min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsHidden" value="true" id="IsHidden" @(Model.IsHidden ? "checked" : "") />
                                <input type="hidden" name="IsHidden" value="false" />
                                <label class="form-check-label text-danger" for="IsHidden">
                                    Ẩn ảnh này
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>