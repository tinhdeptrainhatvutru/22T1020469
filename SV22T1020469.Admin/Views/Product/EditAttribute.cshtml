@model SV22T1020469.Models.Catalog.ProductAttribute
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu thuộc tính
    </button>
    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-list-check me-2"></i> Thông tin thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/SaveAttribute" method="post">
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Tên thuộc tính <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input type="text" name="AttributeName" value="@Model.AttributeName" class="form-control" placeholder="Ví dụ: Màu sắc, Kích thước" required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Giá trị thuộc tính <span class="text-danger">*</span></label>
                        <div class="col-sm-9">
                            <input type="text" name="AttributeValue" value="@Model.AttributeValue" class="form-control" placeholder="Ví dụ: Đỏ, XL, 500g" required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" name="DisplayOrder" value="@Model.DisplayOrder" class="form-control" min="1" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Tồn kho <span class="text-danger">*</span></label>
                        <div class="col-sm-3">
                            <input type="number" name="Quantity" value="@Model.Quantity" class="form-control" min="0" required />
                            @Html.ValidationMessage("Quantity", new { @class = "text-danger" })
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>