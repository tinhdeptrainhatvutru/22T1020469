@model SV22T1020469.Models.Catalog.Product
@{
    Layout = null;
    var attributes = ViewBag.Attributes as List<SV22T1020469.Models.Catalog.ProductAttribute>;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0"><i class="bi bi-list-check me-2"></i> Thuộc tính mặt hàng</h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Attribute/@Model.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i> Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1 table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:120px" class="text-center">Tồn kho</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (attributes != null && attributes.Count > 0)
                        {
                            foreach (var item in attributes)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">@item.AttributeName</td>
                                    <td class="align-middle">@item.AttributeValue</td>
                                    <td class="text-center align-middle">@item.Quantity</td>
                                    <td class="text-center align-middle">@item.DisplayOrder</td>
                                    <td class="text-center align-middle text-nowrap">
                                        <a class="btn btn-sm btn-outline-primary" href="~/Product/Attribute/@Model.ProductID?method=edit&attributeId=@item.AttributeID"><i class="bi bi-pencil"></i></a>
                                        <a class="btn btn-sm btn-outline-danger" href="~/Product/Attribute/@Model.ProductID?method=delete&attributeId=@item.AttributeID"><i class="bi bi-trash"></i></a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted">Chưa có thuộc tính nào được thêm</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>