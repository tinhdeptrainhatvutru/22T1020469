@model SV22T1020469.Models.Sales.OrderViewInfo
@using SV22T1020469.Models.Sales
@{
    ViewData["Title"] = "Đơn hàng #" + Model.OrderID;
    Layout = "_Layout";
    var details = ViewBag.Details as List<SV22T1020469.Models.Sales.OrderDetailViewInfo>
                  ?? new List<SV22T1020469.Models.Sales.OrderDetailViewInfo>();
}

<!-- BREADCRUMB -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Order" asp-action="History">Lịch sử đơn hàng</a></li>
        <li class="breadcrumb-item active">Đơn hàng #@Model.OrderID</li>
    </ol>
</nav>

<!-- TRẠNG THÁI -->
@{
    var (alertCls, iconCls, statusText) = Model.Status switch
    {
        OrderStatusEnum.New       => ("alert-warning",   "bi-hourglass-split",    "Đơn hàng đang chờ nhân viên xác nhận"),
        OrderStatusEnum.Accepted  => ("alert-primary",   "bi-check-circle",       "Đơn hàng đã được xác nhận, đang chuẩn bị"),
        OrderStatusEnum.Shipping  => ("alert-info",      "bi-truck",              "Đơn hàng đang được giao đến bạn"),
        OrderStatusEnum.Completed => ("alert-success",   "bi-check-circle-fill",  "Đơn hàng đã giao thành công"),
        OrderStatusEnum.Cancelled => ("alert-secondary", "bi-slash-circle",       "Đơn hàng đã bị hủy"),
        OrderStatusEnum.Rejected  => ("alert-danger",    "bi-x-circle-fill",      "Đơn hàng bị từ chối"),
        _                         => ("alert-light",     "bi-info-circle",        "Không xác định")
    };
}
<div class="alert @alertCls d-flex align-items-center gap-3 mb-4">
    <i class="bi @iconCls fs-3"></i>
    <div>
        <div class="fw-bold">@statusText</div>
        @if (Model.Status == OrderStatusEnum.Completed && Model.FinishedTime.HasValue)
        {
            <small>Hoàn tất lúc @Model.FinishedTime.Value.ToString("HH:mm, dd/MM/yyyy")</small>
        }
        @if (Model.Status == OrderStatusEnum.Shipping && Model.ShippedTime.HasValue)
        {
            <small>Bàn giao lúc @Model.ShippedTime.Value.ToString("HH:mm, dd/MM/yyyy")</small>
        }
    </div>
</div>

<!-- TIMELINE -->
<div class="card shop-section-card mb-4">
    <div class="card-body py-3">
        <div class="d-flex justify-content-between text-center position-relative">
            <div style="position:absolute;top:18px;left:10%;right:10%;height:3px;background:#dee2e6;z-index:0"></div>
            @{
                var steps = new[]
                {
                    (OrderStatusEnum.New,       "bi-plus-circle",    "Đặt hàng"),
                    (OrderStatusEnum.Accepted,  "bi-check-circle",   "Xác nhận"),
                    (OrderStatusEnum.Shipping,  "bi-truck",          "Đang giao"),
                    (OrderStatusEnum.Completed, "bi-house-check",    "Đã nhận"),
                };
                int currentStep = Model.Status switch
                {
                    OrderStatusEnum.New       => 0,
                    OrderStatusEnum.Accepted  => 1,
                    OrderStatusEnum.Shipping  => 2,
                    OrderStatusEnum.Completed => 3,
                    _                         => -1
                };
            }
            @for (int i = 0; i < steps.Length; i++)
            {
                var (_, ico, lbl) = steps[i];
                bool done    = i <= currentStep && currentStep >= 0;
                bool current = i == currentStep;
                <div class="position-relative" style="z-index:1;flex:1">
                    <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-1"
                         style="width:38px;height:38px;
                                background:@(done ? (current ? "#0d6efd" : "#198754") : "#dee2e6");
                                color:@(done ? "#fff" : "#6c757d")">
                        <i class="bi @ico small"></i>
                    </div>
                    <div class="small @(done ? "fw-bold" : "text-muted")">@lbl</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- THÔNG TIN ĐƠN HÀNG -->
    <div class="col-md-6">
        <div class="card shop-section-card h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-receipt me-1 text-primary"></i>Thông tin đơn hàng
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Mã đơn hàng</dt>
                    <dd class="col-7 fw-bold text-primary">#@Model.OrderID</dd>

                    <dt class="col-5 text-muted">Ngày đặt hàng</dt>
                    <dd class="col-7">@Model.OrderTime.ToString("HH:mm, dd/MM/yyyy")</dd>

                    @if (Model.AcceptTime.HasValue)
                    {
                        <dt class="col-5 text-muted">Ngày xác nhận</dt>
                        <dd class="col-7">@Model.AcceptTime.Value.ToString("HH:mm, dd/MM/yyyy")</dd>
                    }
                    @if (!string.IsNullOrEmpty(Model.EmployeeName))
                    {
                        <dt class="col-5 text-muted">Nhân viên</dt>
                        <dd class="col-7">@Model.EmployeeName</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- THÔNG TIN GIAO HÀNG -->
    <div class="col-md-6">
        <div class="card shop-section-card h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-truck me-1 text-success"></i>Thông tin giao hàng
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    @if (!string.IsNullOrEmpty(Model.DeliveryProvince))
                    {
                        <dt class="col-5 text-muted">Tỉnh/Thành</dt>
                        <dd class="col-7">@Model.DeliveryProvince</dd>
                    }
                    <dt class="col-5 text-muted">Địa chỉ</dt>
                    <dd class="col-7">@Model.DeliveryAddress</dd>

                    @if (!string.IsNullOrEmpty(Model.ShipperName))
                    {
                        <dt class="col-5 text-muted">Người giao</dt>
                        <dd class="col-7">@Model.ShipperName</dd>

                        <dt class="col-5 text-muted">SĐT giao</dt>
                        <dd class="col-7">@Model.ShipperPhone</dd>
                    }
                    @if (Model.ShippedTime.HasValue)
                    {
                        <dt class="col-5 text-muted">Giao lúc</dt>
                        <dd class="col-7">@Model.ShippedTime.Value.ToString("HH:mm, dd/MM/yyyy")</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>

<!-- DANH SÁCH SẢN PHẨM -->
<div class="card shop-section-card mb-4">
    <div class="card-header bg-white fw-semibold">
        <i class="bi bi-box-seam me-1 text-secondary"></i>Sản phẩm đã đặt
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px" class="ps-3">#</th>
                        <th>Sản phẩm</th>
                        <th style="width:80px" class="text-center">ĐVT</th>
                        <th style="width:90px" class="text-center">SL</th>
                        <th style="width:140px" class="text-end">Đơn giá</th>
                        <th style="width:160px" class="text-end pe-3">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int stt = 0; }
                    @foreach (var item in details)
                    {
                        stt++;
                        <tr>
                            <td class="ps-3 text-muted">@stt</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(item.Photo))
                                    {
                                        <img src="@(item.Photo.StartsWith("nophoto.", StringComparison.OrdinalIgnoreCase)
                                                    ? $"/images/{item.Photo}"
                                                    : (item.Photo.StartsWith("products/", StringComparison.OrdinalIgnoreCase)
                                                        ? $"/images/{item.Photo}"
                                                        : $"/images/products/{item.Photo}"))"
                                             style="width:40px;height:40px;object-fit:cover;border-radius:6px"
                                             onerror="this.src='/images/nophoto.svg'" />
                                    }
                                    <span class="fw-semibold">@item.ProductName</span>
                                </div>
                            </td>
                            <td class="text-center text-muted">@item.Unit</td>
                            <td class="text-center">@item.Quantity</td>
                            <td class="text-end text-muted">@item.SalePrice.ToString("N0") đ</td>
                            <td class="text-end pe-3 fw-bold price-tag">@item.TotalPrice.ToString("N0") đ</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <th colspan="5" class="text-end">Tổng cộng</th>
                        <th class="text-end pe-3 price-tag fs-6">
                            @details.Sum(d => d.TotalPrice).ToString("N0") đ
                        </th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- ACTIONS -->
<div class="d-flex gap-2 flex-wrap">
    <a asp-controller="Order" asp-action="History" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại lịch sử
    </a>
    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-shop me-1"></i>Tiếp tục mua sắm
    </a>
</div>
