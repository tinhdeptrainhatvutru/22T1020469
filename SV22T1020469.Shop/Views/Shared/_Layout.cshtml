<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – NKTinhShop" : "NKTinhShop")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="shop-body">
@{
    var user = Context.Session.GetObject<WebUserData>("user");
    var cart = Context.Session.GetObject<List<CartItem>>("cart") ?? new List<CartItem>();
    int cartCount = cart.Sum(x => x.Quantity);
}

<header class="shop-header-v2">
<div class="shop-topbar">
    <div class="container shop-topbar-inner d-flex flex-wrap gap-2 justify-content-between align-items-center small">
        <div class="d-flex flex-wrap gap-3">
            <span><i class="bi bi-lightning-charge-fill me-1"></i>Flash sale mỗi ngày 12:00 - 14:00</span>
            <span><i class="bi bi-truck me-1"></i>Free ship đơn từ 399k</span>
        </div>
        <div class="d-flex flex-wrap gap-3">
            <span><i class="bi bi-shield-check me-1"></i>Đổi trả 7 ngày</span>
            <span><i class="bi bi-headset me-1"></i>Hotline: 1900 1234</span>
        </div>
    </div>
</div>

<nav class="navbar navbar-expand-lg navbar-dark shop-navbar sticky-top">
    <div class="container shop-navbar-inner">
        <a class="navbar-brand shop-brand-mark" asp-controller="Home" asp-action="Index">
            <span class="shop-brand-icon" aria-hidden="true"><i class="bi bi-shop-window"></i></span>
            NKTinhShop
        </a>
        <button class="navbar-toggler shop-nav-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Mở menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <form class="d-flex mx-lg-auto my-3 my-lg-0 shop-search" method="get" asp-controller="Product" asp-action="Index">
                <input name="searchValue" class="form-control form-control-sm"
                       placeholder="Tìm sản phẩm, thương hiệu…" value="@Context.Request.Query["searchValue"]" />
                <button class="btn btn-sm px-3 shop-search-btn" type="submit" aria-label="Tìm kiếm">
                    <i class="bi bi-search"></i>
                </button>
            </form>

            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                <li class="nav-item">
                    <a class="nav-link shop-nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link shop-nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link shop-nav-link shop-nav-cart position-relative" asp-controller="Cart" asp-action="Index" title="Giỏ hàng">
                        <i class="bi bi-cart3 fs-5"></i>
                        @if (cartCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill cart-badge">
                                @(cartCount > 99 ? "99+" : cartCount.ToString())
                            </span>
                        }
                    </a>
                </li>

                @if (user != null)
                {
                    <li class="nav-item">
                        <a class="nav-link shop-nav-link" asp-controller="Order" asp-action="History">Đơn hàng</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link shop-nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-lg-inline text-truncate" style="max-width:9rem">@user.CustomerName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shop-dropdown">
                            <li><h6 class="dropdown-header text-truncate">@user.Email</h6></li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person me-2"></i>Hồ sơ cá nhân
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                    <i class="bi bi-key me-2"></i>Đổi mật khẩu
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="Order" asp-action="History">
                                    <i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link shop-nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    </li>
                    <li class="nav-item ps-lg-1">
                        <a class="btn btn-shop-register btn-sm" asp-controller="Account" asp-action="Register">Đăng ký</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>
</header>

<!-- Thông báo chung (TempData) -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible alert-float fade show shadow" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible alert-float fade show shadow" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<!-- BODY -->
<main class="container py-4 shop-page shop-main-shell">
    @RenderBody()
</main>

<!-- FOOTER -->
<footer class="shop-footer py-5">
    <div class="container">
        <div class="row g-4 g-lg-5">
            <div class="col-md-4">
                <div class="footer-brand">NKTinhShop</div>
                <p class="small mb-3 opacity-90">Mua sắm trực tuyến nhanh chóng, sản phẩm đa dạng và ưu đãi mỗi ngày.</p>
                <div class="d-flex gap-3">
                    <a href="#" class="fs-5" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="fs-5" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="fs-5" aria-label="TikTok"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>
            <div class="col-6 col-md-4">
                <h6>Cửa hàng</h6>
                <ul class="list-unstyled footer-link-list small">
                    <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                    <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-4">
                <h6>Tài khoản</h6>
                <ul class="list-unstyled footer-link-list small">
                    <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                    <li><a asp-controller="Order" asp-action="History">Đơn hàng của tôi</a></li>
                </ul>
            </div>
        </div>
        <hr class="my-4" />
        <p class="mb-0 small text-center text-muted">&copy; 2026 <span class="fw-bold text-primary">NKTinhShop</span> — Giao nhanh, giá tốt mỗi ngày.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Auto-dismiss alerts after 4s
    setTimeout(() => {
        document.querySelectorAll('.alert-float').forEach(el => {
            const bsAlert = bootstrap.Alert.getOrCreateInstance(el);
            if (bsAlert) bsAlert.close();
        });
    }, 4000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
